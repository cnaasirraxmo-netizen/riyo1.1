# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb://localhost:27017/riyo_db

# Security
JWT_SECRET=your_secure_jwt_secret_here

# Firebase Admin SDK (JSON string or file path)
FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json

# Optional: Google Authenticator / 2FA
# 2FA_ISSUER=RIYO_PLATFORM
